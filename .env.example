# ─────────────────────────────────────────────────────────────
# Green and Fluffy — Root env for docker compose (LOCAL DEV ONLY).
# Copy to .env:  cp .env.example .env
# PLACEHOLDERS ONLY — never commit real secrets (public repository).
# These values seed the local containers; they are NOT production creds.
# ─────────────────────────────────────────────────────────────

# ── MySQL ──
MYSQL_ROOT_PASSWORD=root_local_only_change_me
MYSQL_DATABASE=green_fluffy
MYSQL_USER=green_fluffy_user
MYSQL_PASSWORD=change_me_local_only
# Host-published port (container stays on 3306). Non-standard to avoid
# clashing with the myfinpro stack (which already uses 3306+3307).
MYSQL_PORT=3308

# ── Redis ──
# myfinpro already uses 6379+6380, so green-fluffy takes 6381.
REDIS_PORT=6381

# ── Mailpit ──
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025

# ── App published ports ──
API_PORT=3001
WEB_PORT=3000
NGINX_PORT=8080
