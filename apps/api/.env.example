# ─────────────────────────────────────────────
# Green and Fluffy API — Environment Configuration
# Copy to .env and fill in values. PLACEHOLDERS ONLY in this file —
# never commit real secrets (public repository).
# ─────────────────────────────────────────────

# ── Application ──
NODE_ENV=development
API_PORT=3001
API_GLOBAL_PREFIX=api/v1

# ── Database (Prisma) ──
# Host port 3308 maps to the mysql container's 3306 (see root .env / docker-compose).
DATABASE_URL=mysql://green_fluffy_user:change_me_local_only@localhost:3308/green_fluffy

# ── Redis ──
REDIS_HOST=localhost
REDIS_PORT=6381
REDIS_PASSWORD=

# ── CORS ──
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ── Rate Limiting ──
RATE_LIMIT_TTL=60000
RATE_LIMIT_MAX=60
RATE_LIMIT_AUTH_TTL=60000
RATE_LIMIT_AUTH_MAX=5

# ── Swagger ──
SWAGGER_ENABLED=true
SWAGGER_TITLE=Green and Fluffy API
SWAGGER_DESCRIPTION=Care platform for animals and plants
SWAGGER_VERSION=1.0

# ── Logging ──
LOG_LEVEL=debug

# Auth (JWT/Google/Telegram) and SMTP variables are introduced in Phase 1 —
# see docs/phase-1-design.md and .env templates added there.
