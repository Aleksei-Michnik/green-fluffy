# ─────────────────────────────────────────────
# Green and Fluffy Web — Environment Configuration
# Copy to .env and fill in values. PLACEHOLDERS ONLY in this file —
# never commit real secrets (public repository).
# ─────────────────────────────────────────────

# ── Application ──
NODE_ENV=development
PORT=3000

# ── API Connection ──
# Public URL: Used in browser (goes through Nginx)
NEXT_PUBLIC_API_URL=http://localhost/api/v1
# Internal URL: Used for SSR (direct container-to-container)
API_INTERNAL_URL=http://api:3001/api/v1

# ── i18n ──
NEXT_PUBLIC_DEFAULT_LOCALE=en
NEXT_PUBLIC_SUPPORTED_LOCALES=en,he,ru,uk

# Telegram login (NEXT_PUBLIC_TELEGRAM_BOT_ID) is introduced in Phase 1.
